{
  "name": "gua",
  "version": "0.0.0",
  "private": true,
  "description": "Runtime UI automation protocol for games.",
  "license": "MIT",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "check": "bun run --workspaces check",
    "inspector": "bun run --filter @gua/inspector dev",
    "inspector:tauri": "bun run --filter @gua/inspector tauri:dev",
    "bridge:ws": "bun run --filter @gua/bridge-ws dev",
    "mcp": "bun packages/mcp/src/cli.ts mcp"
  }
}
